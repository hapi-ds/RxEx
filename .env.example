# ============================================================================
# Neo4j Database Configuration
# ============================================================================

# NEO4J_URI: Connection string for Neo4j database
# Format: bolt://<host>:<port> or neo4j://<host>:<port>
# Use 'neo4j' as hostname when running in Docker Compose (service name)
# Use 'localhost' when running backend locally outside Docker
NEO4J_URI=bolt://neo4j:7687

# NEO4J_USERNAME: Username for Neo4j authentication
# Default username is 'neo4j' for fresh installations
NEO4J_USERNAME=neo4j

# NEO4J_PASSWORD: Password for Neo4j authentication
# IMPORTANT: Change this in production! Use a strong, unique password
# Minimum 8 characters recommended
NEO4J_PASSWORD=password


# ============================================================================
# JWT Authentication Configuration
# ============================================================================

# JWT_SECRET: Secret key used to sign and verify JWT tokens
# CRITICAL: Must be kept secret and changed in production!
# Generate a secure random string (e.g., using: openssl rand -hex 32)
# Minimum 32 characters recommended for security
JWT_SECRET=your-secret-key-change-in-production

# JWT_ALGORITHM: Algorithm used for JWT token signing
# HS256 (HMAC with SHA-256) is recommended for symmetric key signing
# Other options: HS384, HS512, RS256 (requires public/private key pair)
JWT_ALGORITHM=HS256


# ============================================================================
# Frontend Configuration (Web & XR)
# ============================================================================

# VITE_API_URL: Base URL for backend REST API endpoints
# Used by both web and XR frontends to make HTTP requests
# Format: http://<host>:<port> (no trailing slash)
# Use 'localhost' for local development, update for production deployment
VITE_API_URL=http://localhost:8080

# VITE_WS_URL: WebSocket connection URL for real-time communication
# Used by both web and XR frontends for WebSocket connections
# Format: ws://<host>:<port> for HTTP, wss://<host>:<port> for HTTPS
# Must match the backend WebSocket endpoint location
# Use 'localhost' for local development, update for production deployment
VITE_WS_URL=ws://localhost:8080

# ============================================================================
# AI Provider Configuration
# ============================================================================

# AI_PROVIDER: Which AI provider to use for chat functionality
# Options: none, openai, anthropic, lm-studio, custom
# Set to "none" to disable AI chat features (default)
AI_PROVIDER=none

# AI_API_ENDPOINT: API endpoint URL for the AI provider
# Required when AI_PROVIDER is not "none"
# Examples:
#   LM-Studio (local):  http://localhost:1234/v1
#   OpenAI:             https://api.openai.com/v1
#   Anthropic:          https://api.anthropic.com/v1
AI_API_ENDPOINT=

# AI_API_KEY: API key for authenticating with the AI provider
# Required for: openai, anthropic
# Optional for: lm-studio, custom
# CRITICAL: Keep this secret and never commit to version control!
AI_API_KEY=

# AI_MODEL_NAME: Name of the AI model to use
# Required when AI_PROVIDER is not "none"
# Examples:
#   LM-Studio:  local-model (depends on loaded model)
#   OpenAI:     gpt-4, gpt-3.5-turbo
#   Anthropic:  claude-3-sonnet-20240229
AI_MODEL_NAME=

# AI_REQUEST_TIMEOUT: Timeout in seconds for AI provider requests (default: 60)
# Must be a positive integer
AI_REQUEST_TIMEOUT=60

# AI_MAX_CONTEXT_TOKENS: Maximum tokens for project context in AI prompts (default: 8000)
# Must be a positive integer
AI_MAX_CONTEXT_TOKENS=8000

# AI_MAX_HISTORY_MESSAGES: Maximum conversation history messages sent to AI (default: 20)
AI_MAX_HISTORY_MESSAGES=20

# --- Example Configurations ---
#
# LM-Studio (local, no API key required):
#   AI_PROVIDER=lm-studio
#   AI_API_ENDPOINT=http://localhost:1234/v1
#   AI_MODEL_NAME=local-model
#
# OpenAI (API key required):
#   AI_PROVIDER=openai
#   AI_API_ENDPOINT=https://api.openai.com/v1
#   AI_API_KEY=sk-your-openai-api-key
#   AI_MODEL_NAME=gpt-4
#
# Anthropic (API key required):
#   AI_PROVIDER=anthropic
#   AI_API_ENDPOINT=https://api.anthropic.com/v1
#   AI_API_KEY=sk-ant-your-anthropic-api-key
#   AI_MODEL_NAME=claude-3-sonnet-20240229

# ============================================================================
# Logging Configuration
# ============================================================================

# LOG_LEVEL: Python logging level
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# LOG_FILE: Log file name (written inside LOG_DIR)
LOG_FILE=app.log

# LOG_DIR: Directory for log files (inside the container)
# Mapped to backend_logs Docker volume for persistence
LOG_DIR=/app/logs

# LOG_MAX_SIZE_MB: Maximum size of a single log file in MB before rotation
LOG_MAX_SIZE_MB=10

# LOG_BACKUP_COUNT: Number of rotated backup log files to keep
LOG_BACKUP_COUNT=5
